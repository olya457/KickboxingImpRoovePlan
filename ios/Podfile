# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'KickboxingImpRoovePlan' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix Xcode 26.4 + fmt 11.0.2 `consteval` build failure (fmt/src/format.cc).
    # See expo/expo#44229. Build fmt as C++17 and force-disable FMT_USE_CONSTEVAL.
    installer.pods_project.targets.each do |t|
      next unless t.name == 'fmt'
      t.build_configurations.each do |bc|
        bc.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        defs = bc.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
        defs = [defs] unless defs.is_a?(Array)
        defs << 'FMT_USE_CONSTEVAL=0' unless defs.include?('FMT_USE_CONSTEVAL=0')
        bc.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
      end
    end

    # Belt-and-suspenders: disable consteval directly in the fmt pod header so it
    # can never be re-enabled by the compiler's feature check.
    ['base.h', 'core.h'].each do |header|
      path = File.join(__dir__, 'Pods', 'fmt', 'include', 'fmt', header)
      next unless File.exist?(path)
      text = File.read(path)
      patched = text.gsub('define FMT_USE_CONSTEVAL 1', 'define FMT_USE_CONSTEVAL 0')
      File.write(path, patched) if patched != text
    end
  end
end
